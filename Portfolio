<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Khoa Nguyen Quoc Dang — Engineering Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --white:#FFFFFF;--off-white:#F7F6F3;--light-grey:#EEECE8;--mid-grey:#C8C4BC;
  --text-muted:#8A8680;--text-body:#3D3B38;--text-dark:#1A1917;
  --accent:#2A5EAA;--accent-light:#EBF0FA;--accent-mid:#6B96D4;
  --radius:12px;--radius-sm:6px;
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--off-white);color:var(--text-body);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(247,246,243,0.93);backdrop-filter:blur(12px);border-bottom:1px solid var(--light-grey);padding:0 6vw;height:56px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:'JetBrains Mono',monospace;font-size:.8rem;color:var(--accent);letter-spacing:.05em;font-weight:500}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.82rem;color:var(--text-muted);text-decoration:none;font-weight:500;letter-spacing:.03em;transition:color .2s}
.nav-links a:hover{color:var(--accent)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:0 8vw;padding-top:56px;position:relative;overflow:hidden}
.hero-bg-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(42,94,170,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(42,94,170,.04) 1px,transparent 1px);background-size:48px 48px;animation:gridShift 20s linear infinite}
@keyframes gridShift{0%{background-position:0 0}100%{background-position:48px 48px}}
.hero-blueprint{position:absolute;right:6vw;top:50%;transform:translateY(-50%);width:360px;height:360px;opacity:.07}
.fade-up{opacity:0;animation:fadeUp .8s ease forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-bottom:1.5rem;animation-delay:.2s}
.hero-name{font-family:'DM Serif Display',serif;font-size:clamp(3rem,7vw,6rem);line-height:1.02;color:var(--text-dark);margin-bottom:1rem;animation-delay:.4s}
.hero-name em{font-style:italic;color:var(--accent)}
.hero-sub{font-size:clamp(1rem,2vw,1.2rem);color:var(--text-muted);font-weight:300;margin-bottom:2.5rem;animation-delay:.6s}
.hero-stats{display:flex;gap:3rem;animation-delay:.8s}
.stat-num{font-family:'DM Serif Display',serif;font-size:2.5rem;color:var(--text-dark);line-height:1}
.stat-label{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-top:.3rem}
.hero-scroll{position:absolute;bottom:2.5rem;left:8vw;display:flex;align-items:center;gap:.75rem;font-size:.72rem;color:var(--text-muted);letter-spacing:.08em;text-transform:uppercase;opacity:0;animation:fadeUp .8s ease 1.2s forwards}
.scroll-line{width:40px;height:1px;background:var(--mid-grey);animation:sPulse 2s ease-in-out infinite}
@keyframes sPulse{0%,100%{width:40px;opacity:.5}50%{width:60px;opacity:1}}

/* SECTIONS */
section{padding:6rem 8vw}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-bottom:.75rem}
.sec-title{font-family:'DM Serif Display',serif;font-size:clamp(2rem,4vw,2.8rem);color:var(--text-dark);margin-bottom:1rem;line-height:1.1}
.sec-lead{font-size:1rem;color:var(--text-muted);max-width:580px;line-height:1.75;margin-bottom:3.5rem}

/* SKILLS */
.skills-section{background:var(--white);border-top:1px solid var(--light-grey);border-bottom:1px solid var(--light-grey);padding:4rem 8vw}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:1.25rem;margin-top:2.5rem}
.skill-card{background:var(--off-white);border:1px solid var(--light-grey);border-radius:var(--radius-sm);padding:1.1rem 1.4rem;transition:border-color .2s,transform .2s}
.skill-card:hover{border-color:var(--accent-mid);transform:translateY(-2px)}
.skill-name{font-size:.85rem;font-weight:600;color:var(--text-dark);margin-bottom:.2rem}
.skill-type{font-size:.7rem;color:var(--text-muted);font-family:'JetBrains Mono',monospace}

/* PROJECT CARDS */
.projects-section{background:var(--off-white)}
.project-card{background:var(--white);border:1px solid var(--light-grey);border-radius:var(--radius);overflow:hidden;margin-bottom:3.5rem;opacity:0;transform:translateY(40px);transition:opacity .7s ease,transform .7s ease,box-shadow .3s}
.project-card.visible{opacity:1;transform:translateY(0)}
.project-card:hover{box-shadow:0 12px 40px rgba(42,94,170,.1)}
.card-inner{display:grid;grid-template-columns:1fr 1fr;min-height:400px}
.card-inner.flip{direction:rtl}
.card-inner.flip>*{direction:ltr}
.card-imgs{position:relative;background:var(--light-grey);overflow:hidden}
.card-imgs img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.card-imgs img:hover{transform:scale(1.04)}
.card-body{padding:2.5rem 3rem;display:flex;flex-direction:column;justify-content:center}
.proj-num{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--accent);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.6rem}
.proj-title{font-family:'DM Serif Display',serif;font-size:1.75rem;color:var(--text-dark);line-height:1.2;margin-bottom:.75rem}
.proj-badge{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:.68rem;background:var(--accent-light);color:var(--accent);padding:.28rem .75rem;border-radius:99px;margin-bottom:1.1rem}
.proj-desc{font-size:.9rem;color:var(--text-muted);line-height:1.75;margin-bottom:1.5rem}
.tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1.4rem}
.tag{font-size:.7rem;background:var(--off-white);border:1px solid var(--light-grey);color:var(--text-body);padding:.28rem .7rem;border-radius:99px;font-weight:500}
.highlights{border-top:1px solid var(--light-grey);padding-top:1.1rem}
.hl-label{font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.55rem}
.hl-item{font-size:.8rem;color:var(--text-body);display:flex;align-items:flex-start;gap:.45rem;margin-bottom:.35rem}
.hl-item::before{content:'→';color:var(--accent);font-size:.72rem;margin-top:.1rem;flex-shrink:0}
.drive-btn{display:inline-flex;align-items:center;gap:.5rem;margin-top:1.25rem;padding:.55rem 1.2rem;background:var(--accent);color:#fff;text-decoration:none;border-radius:99px;font-size:.78rem;font-weight:500;letter-spacing:.03em;transition:background .2s,transform .2s}
.drive-btn:hover{background:#1e4a8a;transform:translateY(-1px)}
.drive-btn svg{width:14px;height:14px;flex-shrink:0}

/* PHASE GALLERY */
.phase-gallery{border-top:1px solid var(--light-grey);padding:2rem 3rem;background:var(--off-white)}
.phase-label{font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.9rem}
.phase-tabs{display:flex;gap:.4rem;margin-bottom:1rem}
.ptab{font-size:.72rem;padding:.35rem .9rem;border-radius:99px;border:1px solid var(--light-grey);background:var(--white);cursor:pointer;font-weight:500;color:var(--text-muted);transition:all .2s}
.ptab.active{background:var(--accent);border-color:var(--accent);color:#fff}
.phase-imgs{display:none;grid-template-columns:repeat(3,1fr);gap:.6rem}
.phase-imgs.active{display:grid}
.phase-imgs img{width:100%;height:130px;object-fit:cover;border-radius:var(--radius-sm);transition:transform .4s}
.phase-imgs img:hover{transform:scale(1.04)}

/* FOOTER */
footer{background:var(--text-dark);color:var(--mid-grey);padding:4rem 8vw;text-align:center}
.footer-name{font-family:'DM Serif Display',serif;font-size:2rem;color:#fff;margin-bottom:.4rem}
.footer-sub{font-size:.85rem;color:var(--text-muted);margin-bottom:1.5rem}
.footer-copy{font-size:.72rem;color:var(--text-muted);font-family:'JetBrains Mono',monospace}

.divider{height:1px;background:linear-gradient(90deg,transparent,var(--mid-grey),transparent);margin:0 8vw}

@media(max-width:768px){
  .card-inner{grid-template-columns:1fr}
  .card-inner.flip{direction:ltr}
  .card-imgs{min-height:220px}
  .card-body{padding:1.75rem}
  .phase-gallery{padding:1.5rem}
  .phase-imgs{grid-template-columns:1fr 1fr}
  .hero-stats{gap:1.5rem}
  .nav-links{display:none}
  .hero-blueprint{opacity:.04;width:220px;height:220px}
}

/* WORK TERM */
.workterm-section{background:var(--white);border-top:1px solid var(--light-grey)}
.wt-subhead{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--accent);letter-spacing:.12em;text-transform:uppercase;margin:2.75rem 0 1.25rem}
.wt-subhead.first{margin-top:1rem}
.wt-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem}
.wt-item{background:var(--off-white);border:1px solid var(--light-grey);border-radius:var(--radius);overflow:hidden;transition:box-shadow .3s,transform .2s}
.wt-item:hover{box-shadow:0 12px 40px rgba(42,94,170,.1);transform:translateY(-3px)}
.wt-item img{width:100%;height:260px;object-fit:contain;background:#fff;display:block;border-bottom:1px solid var(--light-grey)}
.wt-cap{padding:1rem 1.25rem}
.wt-cap-title{font-size:.95rem;font-weight:600;color:var(--text-dark);margin-bottom:.25rem}
.wt-cap-sub{font-size:.75rem;color:var(--text-muted);font-family:'JetBrains Mono',monospace}
.wt-cta{margin-top:2.75rem}
</style>
</head>
