<!-- PROJECTS -->
<section class="projects-section" id="projects">
  <p class="eyebrow">Work</p>
  <h2 class="sec-title">Featured Projects</h2>
  <p class="sec-lead">Mechanical engineering design and manufacturing projects completed during my studies — from reverse engineering to pressure vessel design.</p>

  <!-- PROJECT 1 -->
  <div class="project-card" data-reveal>
    <div class="card-inner">
      <div class="card-imgs">
        <img src="data:image/png;base64," alt="Rotor Assembly 3D" />
      </div>
      <div class="card-body">
        <p class="proj-num">Project 01</p>
        <h3 class="proj-title">CNC Machining Rotor Assembly</h3>
        <span class="proj-badge">Metrology Lab</span>
        <p class="proj-desc">Reverse engineered a complete rotor assembly by measuring all components with calipers and micrometers. Reconstructed every part in SolidWorks with full assembly constraints and produced professional engineering drawings using ordinate dimensioning. Parts were CNC-machined and assembled in the lab.</p>
        <div class="tags">
          <span class="tag">SolidWorks</span><span class="tag">CNC Machining</span>
          <span class="tag">Reverse Engineering</span><span class="tag">GD&amp;T</span><span class="tag">Metrology</span>
        </div>
        <div class="highlights">
          <p class="hl-label">Key Deliverables</p>
          <div class="hl-item">5-part SolidWorks models: Bushing, Pillow Block, Rotor, Shaft, Base Plate</div>
          <div class="hl-item">Fully constrained assembly with mating conditions</div>
          <div class="hl-item">Engineering drawings with ordinate dimensioning &amp; GD&amp;T callouts</div>
          <div class="hl-item">Physical CNC-machined aluminium assembly</div>
        </div>
      </div>
    </div>
    <div class="phase-gallery">
      <p class="phase-label">Project Phases</p>
      <div class="phase-tabs">
        <button class="ptab active" onclick="switchPhase(this,'p1-3d')">3D Models</button>
        <button class="ptab" onclick="switchPhase(this,'p1-real')">Machined Result</button>
      </div>
      <div class="phase-imgs active" id="p1-3d">
        <img src="data:image/png;base64," alt="Bushing" />
        <img src="data:image/png;base64," alt="Pillow Block" />
        <img src="data:image/jpeg;base64," alt="Rotor" />
        <img src="data:image/jpeg;base64," alt="Base Plate" />
        <img src="data:image/jpeg;base64," alt="Shaft" />
      </div>
      <div class="phase-imgs" id="p1-real">
        <img src="data:image/jpeg;base64," alt="Real 1" />
        <img src="data:image/jpeg;base64," alt="Real 2" />
        <img src="data:image/jpeg;base64," alt="Real 3" />
      </div>
    </div>
  </div>

  <!-- PROJECT 2 -->
  <div class="project-card" data-reveal>
    <div class="card-inner flip">
      <div class="card-imgs">
        <img src="data:image/jpeg;base64," alt="Centrifugal Clutch Assembly" />
      </div>
      <div class="card-body">
        <p class="proj-num">Project 02</p>
        <h3 class="proj-title">Centrifugal Clutch Design</h3>
        <span class="proj-badge">MECH 200A — Group Project</span>
        <p class="proj-desc">Designed a centrifugal clutch for a 280 W motor at 710 RPM with automatic engagement at 65% of max speed. Calculated tangential forces, friction requirements, shoe mass, centrifugal behaviour, and spring stiffness. All custom parts modelled in SolidWorks with full assembly and part drawings.</p>
        <div class="tags">
          <span class="tag">SolidWorks</span><span class="tag">AISI 1010 Steel</span>
          <span class="tag">Rotational Dynamics</span><span class="tag">Spring Design</span><span class="tag">Friction Analysis</span>
        </div>
        <div class="highlights">
          <p class="hl-label">Key Specs</p>
          <div class="hl-item">Engagement at 65% max speed (461 RPM), 280 W motor</div>
          <div class="hl-item">Spring stiffness k = 15,017 N/m (85.7 lb/in)</div>
          <div class="hl-item">μ = 0.35 friction coefficient, polystyrene lining</div>
          <div class="hl-item">10 components: shoes, drum, shaft, bearing, springs, retainer</div>
        </div>
        <a class="drive-btn" href="https://drive.google.com/drive/folders/1LZHpJdc1LwjececCHcuk_tIEV7wBEXP7?usp=sharing" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.28 3L1 12.5 6.28 22h11.44L23 12.5 17.72 3H6.28zm1.14 2h8.16l4.1 7.1-4.1 7.1H7.42l-4.1-7.1L7.42 5zM12 8.5l-4 7h8l-4-7z"/></svg>
          View Full Report
        </a>
      </div>
    </div>
  </div>

  <!-- PROJECT 3 -->
  <div class="project-card" data-reveal>
    <div class="card-inner">
      <div class="card-imgs">
        <img src="data:image/jpeg;base64," alt="Hydraulic Cylinder Drawing" />
      </div>
      <div class="card-body">
        <p class="proj-num">Project 03</p>
        <h3 class="proj-title">Hydraulic Cylinder Design</h3>
        <span class="proj-badge">MECH 200A — Group Project</span>
        <p class="proj-desc">Designed a double-acting hydraulic cylinder from first principles capable of 10 kN pushing and 7 kN pulling at 10 MPa. Full pressure chamber calculations, ISO thread sizing (M37×1.5), factor of safety analysis, and engagement length checks were completed before generating detailed SolidWorks drawings.</p>
        <div class="tags">
          <span class="tag">SolidWorks</span><span class="tag">Pressure Design</span>
          <span class="tag">AISI 1045 Steel</span><span class="tag">Thread Calculations</span><span class="tag">FOS Analysis</span>
        </div>
        <div class="highlights">
          <p class="hl-label">Key Specs</p>
          <div class="hl-item">10 MPa pressure, 10 kN push / 7 kN pull, FOS = 2</div>
          <div class="hl-item">M37×1.5 ISO metric thread, 5 mm wall thickness</div>
          <div class="hl-item">250 mm stroke, total length 339.76 mm</div>
          <div class="hl-item">7 components: cylinder body, heads, piston, O-rings, fittings</div>
        </div>
        <a class="drive-btn" href="https://drive.google.com/drive/folders/1YkCe8fPUgTCOooLaJTPz8tvHOPxv9EeP?usp=sharing" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.28 3L1 12.5 6.28 22h11.44L23 12.5 17.72 3H6.28zm1.14 2h8.16l4.1 7.1-4.1 7.1H7.42l-4.1-7.1L7.42 5zM12 8.5l-4 7h8l-4-7z"/></svg>
          View Full Report
        </a>
      </div>
    </div>
  </div>

  <!-- PROJECT 4 -->
  <div class="project-card" data-reveal>
    <div class="card-inner flip">
